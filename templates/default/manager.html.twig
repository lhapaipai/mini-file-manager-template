{% extends 'base.html.twig' %}

{% block title %}File manager{% endblock %}

{% block body %}
<div id="file-manager" data-minifilemanager="{{ fileManagerConfig | json_encode | e('html_attr') }}"></div>
{% endblock %}


{% block stylesheets %}
{{ parent() }}
{% if provider == 'ogoxe' %}
{{ vite_entry_link_tags('ogoxeTheme') }}
{% endif %}
{{ vite_entry_link_tags('fileManager') }}
{% endblock %}

{% block javascripts %}
{{ parent() }}
{% if provider == 'ogoxe' %}
{{ vite_entry_script_tags('ogoxeTheme') }}
{% endif %}

{{ vite_entry_script_tags('fileManager') }}
{% endblock %}